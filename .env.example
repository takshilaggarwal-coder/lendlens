# RAG branch: GROQ_API_KEY is required for live synthesized answers.
# Free tier: console.groq.com → API Keys.
# (The app still boots without it, falling back to extractive evidence.)
GROQ_API_KEY=

# Optional — override the Groq-hosted model used for synthesis
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — dense embeddings (text-embedding-3-small) upgrade retrieval to hybrid BM25+dense
OPENAI_API_KEY=
